<div class="mb-6">
    <a href="/stores" class="text-sky-400 hover:text-sky-300 hover:underline flex items-center gap-1 text-sm font-medium transition-colors">
        &larr; Kembali ke Data Store
    </a>
</div>

<div class="glass-panel p-8 max-w-2xl">
    <form action="/stores/update/<%= store.id_store %>" method="POST" class="space-y-6">
        
        <div>
            <label class="block text-sm font-semibold text-slate-300 mb-2">Nama Store</label>
            <input type="text" name="nama_store" required value="<%= store.nama_store %>"
                   class="w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 text-white focus:bg-white/10 focus:ring-2 focus:ring-sky-500 focus:border-transparent outline-none transition-all placeholder-slate-500">
        </div>

        <div class="grid grid-cols-2 gap-4">
            <div>
                <label class="block text-sm font-semibold text-slate-300 mb-2">Kategori</label>
                <select name="kategori" required class="w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 text-white focus:bg-white/10 focus:ring-2 focus:ring-sky-500 focus:border-transparent outline-none transition-all">
                    <option value="Food Store" class="bg-slate-800" <%= store.kategori === 'Food Store' ? 'selected' : '' %>>Food Store (F&B)</option>
                    <option value="Retail Store" class="bg-slate-800" <%= store.kategori === 'Retail Store' ? 'selected' : '' %>>Retail Store (Non-F&B)</option>
                </select>
            </div>
            <div>
                <label class="block text-sm font-semibold text-slate-300 mb-2">Lantai</label>
                <select name="lantai" required class="w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 text-white focus:bg-white/10 focus:ring-2 focus:ring-sky-500 focus:border-transparent outline-none transition-all">
                    <option value="1" class="bg-slate-800" <%= store.lantai == 1 ? 'selected' : '' %>>Lantai 1</option>
                    <option value="2" class="bg-slate-800" <%= store.lantai == 2 ? 'selected' : '' %>>Lantai 2</option>
                    <option value="3" class="bg-slate-800" <%= store.lantai == 3 ? 'selected' : '' %>>Lantai 3</option>
                    <option value="4" class="bg-slate-800" <%= store.lantai == 4 ? 'selected' : '' %>>Lantai 4</option>
                    <option value="5" class="bg-slate-800" <%= store.lantai == 5 ? 'selected' : '' %>>Lantai 5</option>
                </select>
                <p class="text-[10px] uppercase tracking-wider text-slate-500 mt-2">Hanya lantai 1-5 yang diizinkan.</p>
            </div>
        </div>

        <div>
            <label class="block text-sm font-semibold text-slate-300 mb-2">Blok (Sektor 20 Unit/Lantai)</label>
            <select name="blok" required class="w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 text-white focus:bg-white/10 focus:ring-2 focus:ring-sky-500 focus:border-transparent outline-none transition-all">
                <optgroup label="Sektor Kiri" class="bg-slate-800 text-slate-400">
                    <% for(let i=1; i<=10; i++) { %>
                        <option value="A<%= i %>" class="bg-slate-800 text-white" <%= store.blok === `A${i}` ? 'selected' : '' %>>Blok A<%= i %></option>
                    <% } %>
                </optgroup>
                <optgroup label="Sektor Kanan" class="bg-slate-800 text-slate-400">
                    <% for(let i=1; i<=10; i++) { %>
                        <option value="B<%= i %>" class="bg-slate-800 text-white" <%= store.blok === `B${i}` ? 'selected' : '' %>>Blok B<%= i %></option>
                    <% } %>
                </optgroup>
            </select>
        </div>

        <div class="pt-6 border-t border-white/10">
            <button type="submit" class="w-full py-3 bg-sky-600 hover:bg-sky-500 text-white font-bold rounded-xl shadow-lg shadow-sky-900/50 transition-all">
                PERBARUI DATA STORE
            </button>
        </div>
    </form>
</div>

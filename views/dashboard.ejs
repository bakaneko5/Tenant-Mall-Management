<header class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
    <div class="glass-panel p-4 flex flex-col justify-center">
        <p class="text-xs text-slate-400 uppercase tracking-widest">Total Owner</p>
        <h2 class="text-2xl font-bold text-sky-400"><%= stats.totalOwners %></h2>
    </div>
    
    <div class="glass-panel p-4 flex flex-col justify-center">
        <p class="text-xs text-slate-400 uppercase tracking-widest">Total Store</p>
        <h2 class="text-2xl font-bold text-white"><%= stats.totalStores %></h2>
    </div>
</header>

<div class="glass-panel p-5 flex flex-col">
    <h3 class="text-sm font-semibold mb-4 text-white flex items-center gap-2">
        Rancangan Arsitektur Routing & Controller
        <span class="px-2 py-1 text-[10px] bg-sky-500/20 text-sky-400 border border-sky-500/30 rounded-md">Express SSR</span>
    </h3>
    
    <div class="flex-1 overflow-hidden">
        <table class="w-full text-left">
            <thead>
                <tr class="text-[11px] text-slate-500 uppercase tracking-wider">
                    <th class="pb-4 font-medium">Feature</th>
                    <th class="pb-4 font-medium">Method</th>
                    <th class="pb-4 font-medium">Path</th>
                    <th class="pb-4 font-medium">Controller Method</th>
                    <th class="pb-4 font-medium">View Template</th>
                </tr>
            </thead>
            <tbody class="text-sm">
                <% architecture.forEach(item => { %>
                <tr class="border-b border-white/5 hover:bg-white/5 transition-colors">
                    <td class="py-3 font-medium text-slate-200">
                        <div><%= item.feature %></div>
                        <div class="text-[10px] text-slate-500 mt-1"><%= item.description %></div>
                    </td>
                    <td class="py-3">
                        <span class="status-badge <%= item.method === 'GET' ? 'bg-emerald-500/20 text-emerald-400 border border-emerald-500/30' : 'bg-sky-500/20 text-sky-400 border border-sky-500/30' %>">
                            <%= item.method %>
                        </span>
                    </td>
                    <td class="py-3 font-mono text-xs text-slate-400"><%= item.path %></td>
                    <td class="py-3 font-mono text-xs text-slate-400"><%= item.controller %></td>
                    <td class="py-3 text-xs text-slate-400"><%= item.template %></td>
                </tr>
                <% }); %>
            </tbody>
        </table>
    </div>
</div>

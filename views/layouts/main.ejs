<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - Tenant Mall System</title>
    <!-- Tailwind CSS included via CDN for SSR ease or Vite build -->
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body, html {
            margin: 0;
            padding: 0;
            height: 100%;
            overflow: hidden;
            background-color: #0F172A;
            font-family: 'Inter', -apple-system, sans-serif;
            color: #cbd5e1; /* slate-300 */
        }
        .glass-bg {
            background: radial-gradient(circle at 0% 0%, #1e293b 0%, #0f172a 100%);
            height: 100%;
            width: 100%;
            position: relative;
        }
        .orb {
            position: absolute;
            border-radius: 50%;
            filter: blur(80px);
            z-index: 0;
        }
        .orb-1 { width: 400px; height: 400px; background: rgba(30, 64, 175, 0.3); top: -100px; left: -100px; }
        .orb-2 { width: 500px; height: 500px; background: rgba(126, 34, 206, 0.2); bottom: -150px; right: -50px; }
        .glass-panel {
            background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 16px;
        }
        .glass-card {
            background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(8px);
            border: 1px solid rgba(255, 255, 255, 0.08);
            transition: background 0.3s ease;
        }
        .active-nav {
            background: rgba(255, 255, 255, 0.1);
            border-left: 4px solid #38bdf8;
        }
        .status-badge {
            font-size: 10px;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            padding: 2px 8px;
            border-radius: 9999px;
        }
    </style>
</head>
<body class="antialiased font-sans flex text-slate-200">
    <div class="glass-bg flex w-full h-full">
        <div class="orb orb-1"></div>
        <div class="orb orb-2"></div>
        
        <!-- Sidebar -->
        <aside class="w-64 glass-panel m-4 flex flex-col z-10 hidden md:flex">
            <div class="p-6 flex items-center gap-3">
                <div class="w-8 h-8 bg-sky-500 rounded-lg flex items-center justify-center font-bold text-white">M</div>
                <h1 class="text-xl font-bold tracking-tight text-white">MallTenant v1</h1>
            </div>
            
            <nav class="flex-1 px-4 space-y-2 py-4">
                <a href="/" class="flex items-center p-3 rounded-xl cursor-pointer <%= currentPath === '/' ? 'active-nav' : 'hover:bg-white/5' %> transition-all duration-200">
                    <span class="text-sm font-medium <%= currentPath === '/' ? 'text-white' : 'text-slate-400' %>">Dashboard Overview</span>
                </a>
                <a href="/owners" class="flex items-center p-3 rounded-xl cursor-pointer <%= currentPath.startsWith('/owners') ? 'active-nav' : 'hover:bg-white/5' %> transition-all duration-200">
                    <span class="text-sm font-medium <%= currentPath.startsWith('/owners') ? 'text-white' : 'text-slate-400' %>">Kelola Owner</span>
                </a>
                <a href="/stores" class="flex items-center p-3 rounded-xl cursor-pointer <%= currentPath === '/stores' || currentPath === '/stores/create' ? 'active-nav' : 'hover:bg-white/5' %> transition-all duration-200">
                    <span class="text-sm font-medium <%= currentPath === '/stores' || currentPath === '/stores/create' ? 'text-white' : 'text-slate-400' %>">Kelola Store</span>
                </a>
                <a href="/stores/map" class="flex items-center p-3 rounded-xl cursor-pointer <%= currentPath === '/stores/map' ? 'active-nav' : 'hover:bg-white/5' %> transition-all duration-200">
                    <span class="text-sm font-medium <%= currentPath === '/stores/map' ? 'text-white' : 'text-slate-400' %>">Zonasi Store (Denah)</span>
                </a>
                <a href="/contracts" class="flex items-center p-3 rounded-xl cursor-pointer <%= currentPath.startsWith('/contracts') ? 'active-nav' : 'hover:bg-white/5' %> transition-all duration-200">
                    <span class="text-sm font-medium <%= currentPath.startsWith('/contracts') ? 'text-white' : 'text-slate-400' %>">Kontrak Sewa</span>
                </a>
                <a href="/payments" class="flex items-center p-3 rounded-xl cursor-pointer <%= currentPath.startsWith('/payments') ? 'active-nav' : 'hover:bg-white/5' %> transition-all duration-200">
                    <span class="text-sm font-medium <%= currentPath.startsWith('/payments') ? 'text-white' : 'text-slate-400' %>">Validasi Bayar</span>
                </a>
            </nav>
            
            <div class="p-6 border-t border-white/10">
                <div class="flex items-center gap-3 p-2">
                    <div class="w-10 h-10 rounded-full bg-slate-700 flex items-center justify-center border border-white/20 text-xs text-white">ADM</div>
                    <div>
                        <p class="text-xs font-semibold text-white">Super Admin</p>
                        <p class="text-[10px] text-slate-400">Admin Server</p>
                    </div>
                </div>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="flex-1 py-4 pr-4 pl-4 md:pl-0 flex flex-col z-10 w-full overflow-hidden">
            
            <!-- Navbar Mobile -->
            <header class="glass-panel p-4 mb-4 flex justify-between items-center md:hidden shrink-0">
                <div class="flex items-center gap-3">
                    <div class="w-8 h-8 bg-sky-500 rounded-lg flex items-center justify-center font-bold text-white">M</div>
                    <h1 class="text-lg font-bold text-white">MallTenant</h1>
                </div>
                <button class="p-2 border border-white/10 rounded-lg text-slate-300 hover:text-white">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
                </button>
            </header>

            <div class="mb-4 shrink-0 px-2 lg:px-4">
                <h2 class="text-2xl font-bold text-white"><%= title %></h2>
            </div>
            
            <div class="flex-1 overflow-auto rounded-2xl relative">
                <div class="absolute inset-0 p-2 lg:p-4 pb-20 md:pb-10">
                    <%- body %>
                </div>
            </div>
            
        </main>
        
    </div>
</body>
</html>

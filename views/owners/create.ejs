<div class="mb-6">
    <a href="/owners" class="text-sky-400 hover:text-sky-300 hover:underline flex items-center gap-1 text-sm font-medium transition-colors">
        &larr; Kembali ke Data Owner
    </a>
</div>

<div class="glass-panel p-8 max-w-2xl">
    <form action="/owners/store" method="POST" class="space-y-6">
        
        <div>
            <label class="block text-sm font-semibold text-slate-300 mb-2">Nama Lengkap / Nama Perusahaan</label>
            <input type="text" name="nama_owner" required
                   class="w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 text-white focus:bg-white/10 focus:ring-2 focus:ring-sky-500 focus:border-transparent outline-none transition-all placeholder-slate-500" placeholder="Contoh: PT. Maju Jaya / Budi Santoso">
        </div>

        <div>
            <label class="block text-sm font-semibold text-slate-300 mb-2">Tipe Owner</label>
            <div class="flex gap-4">
                <label class="flex-1 cursor-pointer group">
                    <input type="radio" name="tipe_owner" value="Individu" class="peer sr-only" checked>
                    <div class="px-4 py-3 rounded-xl bg-white/5 border border-white/10 text-center peer-checked:bg-emerald-500/20 peer-checked:border-emerald-500/50 peer-checked:text-emerald-400 transition-all font-medium text-slate-400 group-hover:bg-white/10">
                        Individu
                    </div>
                </label>
                <label class="flex-1 cursor-pointer group">
                    <input type="radio" name="tipe_owner" value="Perusahaan" class="peer sr-only">
                    <div class="px-4 py-3 rounded-xl bg-white/5 border border-white/10 text-center peer-checked:bg-purple-500/20 peer-checked:border-purple-500/50 peer-checked:text-purple-400 transition-all font-medium text-slate-400 group-hover:bg-white/10">
                        Perusahaan
                    </div>
                </label>
            </div>
        </div>

        <div>
            <label class="block text-sm font-semibold text-slate-300 mb-2">Nomor Telepon</label>
            <input type="text" name="no_telp" required
                   class="w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 text-white focus:bg-white/10 focus:ring-2 focus:ring-sky-500 focus:border-transparent outline-none transition-all placeholder-slate-500" placeholder="Contoh: 08123456789 (Bisa lebih dari 1 pisahkan dengan koma)">
            <p class="text-[10px] uppercase tracking-wider text-slate-500 mt-2">Sesuai aturan bisnis, owner boleh memiliki lebih dari 1 nomor telepon.</p>
        </div>

        <div>
            <label class="block text-sm font-semibold text-slate-300 mb-2">Alamat Lengkap</label>
            <textarea name="alamat" required rows="3"
                      class="w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 text-white focus:bg-white/10 focus:ring-2 focus:ring-sky-500 focus:border-transparent outline-none transition-all placeholder-slate-500" placeholder="Jalan, Kota, Kode Pos..."></textarea>
            <p class="text-[10px] uppercase tracking-wider text-slate-500 mt-2">Sesuai aturan bisnis, wajib mencantumkan Jalan, Kota, Kode Pos.</p>
        </div>

        <div class="pt-6 border-t border-white/10">
            <button type="submit" class="w-full py-3 bg-sky-600 hover:bg-sky-500 text-white font-bold rounded-xl shadow-lg shadow-sky-900/50 transition-all">
                SIMPAN DATA OWNER
            </button>
        </div>
    </form>
</div>

<div class="mb-6">
    <a href="/contracts" class="text-sky-400 hover:text-sky-300 hover:underline flex items-center gap-1 text-sm font-medium transition-colors">
        &larr; Kembali ke Data Kontrak
    </a>
</div>

<div class="glass-panel p-8 max-w-2xl">
    <form action="/contracts/store" method="POST" class="space-y-6">
        
        <div class="grid grid-cols-2 gap-4">
            <div>
                <label class="block text-sm font-semibold text-slate-300 mb-2">Pilih Owner</label>
                <select name="id_owner" required class="w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 text-white focus:bg-white/10 focus:ring-2 focus:ring-sky-500 focus:border-transparent outline-none transition-all">
                    <option value="" class="bg-slate-800">-- Pilih Owner --</option>
                    <% owners.forEach(o => { %>
                        <option value="<%= o.id_owner %>" class="bg-slate-800"><%= o.nama_owner %> (<%= o.tipe_owner %>)</option>
                    <% }); %>
                </select>
            </div>
            <div>
                <label class="block text-sm font-semibold text-slate-300 mb-2">Pilih Store Kosong</label>
                <select name="id_store" required class="w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 text-white focus:bg-white/10 focus:ring-2 focus:ring-sky-500 focus:border-transparent outline-none transition-all">
                    <option value="" class="bg-slate-800">-- Pilih Store --</option>
                    <% stores.forEach(s => { %>
                        <option value="<%= s.id_store %>" class="bg-slate-800"><%= s.nama_store %> (Lt.<%= s.lantai %>, <%= s.blok %>)</option>
                    <% }); %>
                </select>
            </div>
        </div>

        <div class="grid grid-cols-2 gap-4">
            <div>
                <label class="block text-sm font-semibold text-slate-300 mb-2">Tanggal Mulai</label>
                <input type="date" id="tanggal_mulai" name="tanggal_mulai" required class="w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 text-white focus:bg-white/10 focus:ring-2 focus:ring-sky-500 outline-none">
            </div>
            <div>
                <label class="block text-sm font-semibold text-slate-300 mb-2">Tanggal Selesai (Otomatis)</label>
                <input type="text" id="tanggal_selesai_display" disabled placeholder="Dihitung otomatis..." class="w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 text-slate-500 focus:outline-none cursor-not-allowed">
            </div>
        </div>

        <div>
            <label class="block text-sm font-semibold text-slate-300 mb-2">Jenis Kontrak & Durasi</label>
            <div class="flex gap-4">
                <label class="flex-1 cursor-pointer group">
                    <input type="radio" name="jenis_kontrak" value="Bulanan" class="peer sr-only" checked>
                    <div class="px-4 py-4 rounded-xl bg-white/5 border border-white/10 text-center peer-checked:bg-sky-500/20 peer-checked:border-sky-500/50 peer-checked:text-sky-400 transition-all text-slate-400 group-hover:bg-white/10 relative overflow-hidden">
                        <div class="font-bold text-sm">Bulanan</div>
                        <div class="text-[10px] mt-1 text-slate-500">10 Jt/bln, Dep 50%</div>
                    </div>
                </label>
                <label class="flex-1 cursor-pointer group">
                    <input type="radio" name="jenis_kontrak" value="Tahunan" class="peer sr-only">
                    <div class="px-4 py-4 rounded-xl bg-white/5 border border-white/10 text-center peer-checked:bg-purple-500/20 peer-checked:border-purple-500/50 peer-checked:text-purple-400 transition-all text-slate-400 group-hover:bg-white/10 relative overflow-hidden">
                        <div class="font-bold text-sm">Tahunan</div>
                        <div class="text-[10px] mt-1 text-slate-500">100 Jt/thn, Dep 25%</div>
                    </div>
                </label>
            </div>
        </div>
        
        <div>
            <label id="label_durasi" class="block text-sm font-semibold text-slate-300 mb-2">Durasi (Bulan)</label>
            <input type="number" id="durasi" name="durasi" required min="1" value="1" class="w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 text-white focus:bg-white/10 focus:ring-2 focus:ring-sky-500 focus:border-transparent outline-none transition-all">
        </div>

        <div class="pt-6 border-t border-white/10">
            <button type="submit" class="w-full py-3 bg-sky-600 hover:bg-sky-500 text-white font-bold rounded-xl shadow-lg shadow-sky-900/50 transition-all">
                BUAT & SIMPAN KONTRAK
            </button>
        </div>
    </form>
</div>

<script>
    const inputMulai = document.getElementById('tanggal_mulai');
    const inputSelesaiDisplay = document.getElementById('tanggal_selesai_display');
    const inputDurasi = document.getElementById('durasi');
    const labelDurasi = document.getElementById('label_durasi');
    const radios = document.querySelectorAll('input[name="jenis_kontrak"]');

    function calculateEnd() {
        if (!inputMulai.value || !inputDurasi.value) return;
        const start = new Date(inputMulai.value);
        let jenis = 'Bulanan';
        radios.forEach(r => { if(r.checked) jenis = r.value; });
        
        // Update label
        if (jenis === 'Bulanan') {
            labelDurasi.innerText = 'Berapa Bulan?';
        } else {
            labelDurasi.innerText = 'Berapa Tahun?';
        }

        const durasiVal = parseInt(inputDurasi.value) || 1;
        const end = new Date(start);
        
        if (jenis === 'Bulanan') {
            end.setMonth(end.getMonth() + durasiVal);
        } else {
            end.setFullYear(end.getFullYear() + durasiVal);
        }
        
        inputSelesaiDisplay.value = end.toLocaleDateString('id-ID', {
            day: '2-digit', month: 'long', year: 'numeric'
        });
    }

    inputMulai.addEventListener('change', calculateEnd);
    inputDurasi.addEventListener('input', calculateEnd);
    radios.forEach(r => r.addEventListener('change', calculateEnd));
</script>
